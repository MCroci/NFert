Package: NFert
Title: N, P and K fertilization following Emilia-Romagna DPI 2026
Version: 0.4.0
URL: https://github.com/mcroci/NFert
BugReports: https://github.com/mcroci/NFert/issues
Authors@R: 
    c(
        person("Michele", "Croci", email = "michele.croci@unicatt.it", role = c("aut", "cre")),
        person("Manuele", "Ragazzi", role = "aut"),
        person("Giorgio", "Impollonia", role = "aut"),
