# =============================================================================
# EXPORT MAPPE DI PRESCRIZIONE - Multi-formato
# =============================================================================
# Funzioni per esportare una mappa di prescrizione (oggetto sf) nei principali
# formati accettati dai monitor di bordo.
#
# Formati supportati:
#   - Shapefile (universale)
#   - GeoJSON
#   - KML
#   - GeoPackage (GPKG)
#   - ISOXML (TASKDATA.XML) - standard ISOBUS ISO 11783-10
#   - Shapefile "John Deere ready"
#   - Shapefile "Trimble ready"
# =============================================================================
library(sf)
library(dplyr)
library(xml2)
# -----------------------------------------------------------------------------
# Funzione di pulizia/preparazione (base per tutti gli export)
# -----------------------------------------------------------------------------
# - Riproietta in WGS84 (EPSG:4326) - richiesto da quasi tutti i monitor
# - Valida le geometrie
# - Rimuove sliver < 1 m^2
# - Rinomina il campo dose come richiesto dal formato target
# -----------------------------------------------------------------------------
prepara_mappa <- function(mappa, dose_field = "dose",
dose_name_out = "DOSE",
decimali = 1,
area_min = 1) {
if (!inherits(mappa, "sf")) stop("mappa deve essere un oggetto sf")
if (!dose_field %in% names(mappa)) stop("Campo dose '", dose_field, "' non trovato")
# Calcolo area in metri (richiede CRS metrico temporaneo)
crs_orig <- st_crs(mappa)
if (st_is_longlat(mappa)) {
mappa_m <- st_transform(mappa, 3857)
} else {
mappa_m <- mappa
}
mappa$area_m2 <- as.numeric(st_area(mappa_m))
out <- mappa |>
filter(area_m2 >= area_min) |>
st_make_valid() |>
st_transform(4326)
# Rinomina e arrotonda la dose
out[[dose_name_out]] <- round(out[[dose_field]], decimali)
# Aggiungi ID univoco
out$ID <- seq_len(nrow(out))
# Mantieni solo i campi essenziali
out <- out[, c("ID", dose_name_out, "area_m2")]
out
}
# -----------------------------------------------------------------------------
# 1. SHAPEFILE - formato universale
# -----------------------------------------------------------------------------
export_shapefile <- function(mappa, path, dose_field = "dose") {
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "DOSE", decimali = 1)
st_write(out, path, delete_dsn = TRUE, quiet = TRUE)
message("Shapefile salvato: ", path)
invisible(out)
}
# -----------------------------------------------------------------------------
# 2. GEOJSON - utile per web / QGIS / controllo
# -----------------------------------------------------------------------------
export_geojson <- function(mappa, path, dose_field = "dose") {
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "dose", decimali = 2)
st_write(out, path, delete_dsn = TRUE, quiet = TRUE)
message("GeoJSON salvato: ", path)
invisible(out)
}
# -----------------------------------------------------------------------------
# 3. KML - visualizzazione in Google Earth
# -----------------------------------------------------------------------------
export_kml <- function(mappa, path, dose_field = "dose") {
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "dose", decimali = 1)
# KML richiede Z coord a volte: forziamo 2D
out <- st_zm(out, drop = TRUE, what = "ZM")
st_write(out, path, driver = "KML", delete_dsn = TRUE, quiet = TRUE)
message("KML salvato: ", path)
invisible(out)
}
# -----------------------------------------------------------------------------
# 4. GEOPACKAGE - formato moderno, single-file
# -----------------------------------------------------------------------------
export_gpkg <- function(mappa, path, dose_field = "dose",
layer_name = "prescrizione") {
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "dose", decimali = 2)
st_write(out, path, layer = layer_name,
delete_dsn = TRUE, quiet = TRUE)
message("GeoPackage salvato: ", path)
invisible(out)
}
# -----------------------------------------------------------------------------
# 5. SHAPEFILE "John Deere ready"
# -----------------------------------------------------------------------------
# Accortezze: WGS84, campo dose INTERO chiamato RATE, nome file corto, no accenti
# -----------------------------------------------------------------------------
export_johndeere <- function(mappa, path, dose_field = "dose") {
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "RATE", decimali = 0)
out$RATE <- as.integer(out$RATE)
st_write(out, path, delete_dsn = TRUE, quiet = TRUE)
message("Shapefile JD salvato: ", path)
invisible(out)
}
# -----------------------------------------------------------------------------
# 6. SHAPEFILE "Trimble ready" (FmX / GFX / TMX)
# -----------------------------------------------------------------------------
# Accortezze: WGS84, campo TGT_RATE, ID univoco obbligatorio
# -----------------------------------------------------------------------------
export_trimble <- function(mappa, path, dose_field = "dose") {
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "TGT_RATE", decimali = 1)
st_write(out, path, delete_dsn = TRUE, quiet = TRUE)
message("Shapefile Trimble salvato: ", path)
invisible(out)
}
# -----------------------------------------------------------------------------
# 7. ISOXML (TASKDATA.XML) - standard ISO 11783-10
# -----------------------------------------------------------------------------
# Crea una cartella con TASKDATA.XML e il poligono trattamento come GRD
# Nota: implementazione semplificata, copre il caso "prescription map a zone".
# Per sistemi complessi (prodotti multipli, time-based) serve estendere.
# -----------------------------------------------------------------------------
export_isoxml <- function(mappa, dir_path,
dose_field  = "dose",
nome_task   = "Prescrizione",
nome_campo  = "Campo1",
coltura     = "Cereale",
prodotto    = "Fertilizzante",
unita       = "kg/ha",
ddi_code    = "0006") {   # 0006 = mass per area
if (!dir.exists(dir_path)) dir.create(dir_path, recursive = TRUE)
out <- prepara_mappa(mappa, dose_field = dose_field,
dose_name_out = "DOSE", decimali = 1)
# Radice ISO11783_TaskData
root <- xml_new_root("ISO11783_TaskData",
VersionMajor = "4", VersionMinor = "2",
ManagementSoftwareManufacturer = "R-script",
ManagementSoftwareVersion = "1.0",
DataTransferOrigin = "1")
# Partfield (il campo)
xml_add_child(root, "PFD",
A = "PFD1", C = nome_campo,
D = as.character(round(sum(out$area_m2))))
# Crop type
xml_add_child(root, "CTP", A = "CTP1", B = coltura)
# Product
xml_add_child(root, "PDT", A = "PDT1", B = prodotto)
# Task
tsk <- xml_add_child(root, "TSK",
A = "TSK1", B = nome_task,
C = "PFD1", E = "1", G = "1")
# Treatment zones - una zona per cella con dose distinta
# (in realt\u00e0 ISOXML raggruppa per fascia di dose, qui semplifichiamo)
dosi_uniche <- sort(unique(out$DOSE))
for (k in seq_along(dosi_uniche)) {
d <- dosi_uniche[k]
tzn <- xml_add_child(tsk, "TZN",
A = sprintf("TZN%d", k),
B = sprintf("Dose %s %s", d, unita))
# Process Data Variable - dose target
xml_add_child(tzn, "PDV",
A = ddi_code,                         # DDI
B = as.character(as.integer(d * 100)),# valore (scala x100)
C = "PDT1")
}
# Polygon geometries (una PLN per cella, legata alla TZN con stessa dose)
coords_list <- st_coordinates(out)
for (i in seq_len(nrow(out))) {
k <- match(out$DOSE[i], dosi_uniche)
tzn_ref <- sprintf("TZN%d", k)
# Trova la TZN giusta e aggiungi il poligono
tzn_node <- xml_find_first(tsk,
sprintf(".//TZN[@A='%s']", tzn_ref))
pln <- xml_add_child(tzn_node, "PLN", A = "1")  # 1 = partfield boundary
lsg <- xml_add_child(pln, "LSG", A = "1")        # 1 = exterior
pts <- coords_list[coords_list[, "L2"] == i, , drop = FALSE]
for (r in seq_len(nrow(pts))) {
xml_add_child(lsg, "PNT",
A = "2",                              # 2 = other
C = sprintf("%.8f", pts[r, "Y"]),     # Lat
D = sprintf("%.8f", pts[r, "X"]))     # Lon
}
}
xml_file <- file.path(dir_path, "TASKDATA.XML")
write_xml(root, xml_file)
message("ISOXML salvato in: ", dir_path, "/TASKDATA.XML")
invisible(xml_file)
}
# =============================================================================
# FUNZIONE "TUTTO IN UNO"
# =============================================================================
# Esporta tutti i formati in una cartella. Scegli con il parametro 'formati'.
# =============================================================================
esporta_tutti <- function(mappa,
cartella_output = "output_prescrizione",
nome_base       = "prescrizione",
dose_field      = "dose",
formati = c("shp", "geojson", "kml", "gpkg",
"johndeere", "trimble", "isoxml")) {
if (!dir.exists(cartella_output)) dir.create(cartella_output, recursive = TRUE)
formati <- tolower(formati)
risultati <- list()
if ("shp" %in% formati) {
risultati$shp <- export_shapefile(
mappa, file.path(cartella_output, paste0(nome_base, ".shp")),
dose_field)
}
if ("geojson" %in% formati) {
risultati$geojson <- export_geojson(
mappa, file.path(cartella_output, paste0(nome_base, ".geojson")),
dose_field)
}
if ("kml" %in% formati) {
risultati$kml <- export_kml(
mappa, file.path(cartella_output, paste0(nome_base, ".kml")),
dose_field)
}
if ("gpkg" %in% formati) {
risultati$gpkg <- export_gpkg(
mappa, file.path(cartella_output, paste0(nome_base, ".gpkg")),
dose_field)
}
if ("johndeere" %in% formati) {
jd_dir <- file.path(cartella_output, "johndeere")
if (!dir.exists(jd_dir)) dir.create(jd_dir)
risultati$johndeere <- export_johndeere(
mappa, file.path(jd_dir, paste0(nome_base, "_JD.shp")),
dose_field)
}
if ("trimble" %in% formati) {
tr_dir <- file.path(cartella_output, "trimble")
if (!dir.exists(tr_dir)) dir.create(tr_dir)
risultati$trimble <- export_trimble(
mappa, file.path(tr_dir, paste0(nome_base, "_TR.shp")),
dose_field)
}
if ("isoxml" %in% formati) {
iso_dir <- file.path(cartella_output, "TASKDATA")
risultati$isoxml <- export_isoxml(mappa, iso_dir, dose_field)
}
message("\n=== Export completato ===")
message("Cartella: ", normalizePath(cartella_output))
invisible(risultati)
}
