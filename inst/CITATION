citHeader("To cite NFert in publications use:")

# `meta` is the package DESCRIPTION when read during R CMD check / build;
# fall back to the installed description otherwise. Avoids packageVersion(),
# which errors when the package is not yet installed.
if (!exists("meta") || is.null(meta)) meta <- utils::packageDescription("NFert")
ver <- meta[["Version"]]

bibentry(
  bibtype = "Manual",
  title = "NFert: N, P and K Fertilization Following Emilia-Romagna DPI 2026",
  author = c(
    person("Michele", "Croci", role = c("aut", "cre"),
           email = "michele.croci@unicatt.it"),
    person("Manuele", "Ragazzi", role = "aut"),
    person("Giorgio", "Impollonia", role = "aut"),
    person("Stefano", "Amaducci", role = "aut")
  ),
  year = 2026,
  note = paste("R package version", ver),
  url = "https://github.com/mcroci/NFert",
  textVersion = paste0(
    "Croci M, Ragazzi M, Impollonia G, Amaducci S (2026). ",
    "NFert: N, P and K Fertilization Following Emilia-Romagna DPI 2026. ",
    "R package version ", ver, ". ",
    "https://github.com/mcroci/NFert"
  )
)
